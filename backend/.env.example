# ─── Shared ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://dating:dating@postgres:5432/dating
REDIS_URL=redis://redis:6379
APP_ENV=dev   # dev | prod

# ─── API ─────────────────────────────────────────────────────────────────────
BOT_SECRET=change-me-in-production
# Optional: enables Google Maps geocoding fallback when set
GOOGLE_MAPS_API_KEY=

# ─── Bot ─────────────────────────────────────────────────────────────────────
BOT_TOKEN=1234567890:AABBCCDDEEFFaabbccddeeff
API_BASE_URL=http://api:8000
API_SECRET=change-me-in-production     # must match BOT_SECRET

# Polling (dev default) – no extra config needed.
# Webhook (prod) – set these:
BOT_TRANSPORT=polling                  # polling | webhook
WEBHOOK_URL=https://bot.example.com/webhook
WEBHOOK_PORT=8443
# Telegram will include this token in the X-Telegram-Bot-Api-Secret-Token header.
WEBHOOK_SECRET_TOKEN=change-me-in-production
