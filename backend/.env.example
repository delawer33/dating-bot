# ─── Shared ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://dating:dating@postgres:5432/dating
REDIS_URL=redis://redis:6379
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672//
CELERY_BROKER_URL=amqp://guest:guest@rabbitmq:5672//
CELERY_RESULT_BACKEND=redis://redis:6379/1
APP_ENV=dev   # dev | prod
# Optional: enables https://t.me/<bot>?start=<referral_code> in POST /registration/referral
# TELEGRAM_BOT_USERNAME=my_dating_bot

# ─── API ─────────────────────────────────────────────────────────────────────
BOT_SECRET=change-me-in-production
# Same token as the bot: required for getFile + download in /registration/photo;
# also used by `behavior_consumer` for Telegram push (incoming like / match).
BOT_TOKEN=1234567890:AABBCCDDEEFFaabbccddeeff
# MinIO (S3-compatible) — in Docker, service host is "minio"
S3_ENDPOINT_URL=http://minio:9000
S3_ACCESS_KEY=minio
S3_SECRET_KEY=miniochange
S3_BUCKET=photos
S3_REGION=us-east-1
# Registration photos (defaults match API if unset)
# REGISTRATION_MIN_PHOTOS=1
# REGISTRATION_MAX_PHOTOS=6
# Optional: enables Google Maps geocoding fallback when set
GOOGLE_MAPS_API_KEY=

# ─── Bot ─────────────────────────────────────────────────────────────────────
# BOT_TOKEN: duplicate line above; single .env is shared with api in compose
API_BASE_URL=http://api:8000
API_SECRET=change-me-in-production     # must match BOT_SECRET

# Polling (dev default) – no extra config needed.
# Webhook (prod) – set these:
BOT_TRANSPORT=polling                  # polling | webhook
WEBHOOK_URL=https://bot.example.com/webhook
WEBHOOK_PORT=8443
# Telegram will include this token in the X-Telegram-Bot-Api-Secret-Token header.
WEBHOOK_SECRET_TOKEN=change-me-in-production
